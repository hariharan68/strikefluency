# ══════════════════════════════════════════════════
# StrikeFluency — Root .gitignore
# ══════════════════════════════════════════════════

# ── Environment / Secrets (NEVER commit) ─────────
.env
.env.*
!.env.example
*.env
secrets.json
credentials.json

# Fyers API tokens / logs
fyers_logs/
fyers_token.json
access_token.txt

# ── Python ────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyw
.Python

# Virtual environments
venv/
.venv/
env/
ENV/
.virtualenv/

# Packaging / distribution
*.egg-info/
*.egg
dist/
build/
wheels/
pip-wheel-metadata/
MANIFEST

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover
.hypothesis/
AGENTS.md

# MyPy / type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/

# ── Node / Frontend ───────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Vite build output
frontend/dist/
frontend/dist-ssr/
frontend/.vite/
frontend/coverage/

# Local env files (Vite convention)
*.local

# ── Logs ──────────────────────────────────────────
logs/
*.log
log/

# ── IDE / Editor ──────────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.user
*.swp
*.swo
*~
.vim/

# ── OS ────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini
ehthumbs.db

# ── Alembic ───────────────────────────────────────
# versions/ IS committed — it holds migration history
# alembic.ini IS committed — project config

# ── Misc ──────────────────────────────────────────
*.bak
*.tmp
*.temp
.cache/
