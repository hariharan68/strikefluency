# StrikeFluency â€” Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€

# Database (your local Postgres)
DATABASE_URL=postgresql://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/strikefluency

# JWT â€” generate a real secret with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-this-with-a-real-64-char-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# App
ENVIRONMENT=development

# Market data
MOCK_MARKET_DATA=true
NIFTY_LOT_SIZE=65

# Market data
MARKET_DATA_PROVIDER=fyers

# Fyers credentials
FYERS_CLIENT_ID=FXXXXXXXXXXX
FYERS_APP_ID=XXXXXXXXXXXXXX
FYERS_SECRET_ID=BXXXXXXXXXXXXXX
FYERS_REDIRECT_URI=http://localhost:8001/api/v1/auth/fyers/callback
FYERS_ACCESS_TOKEN=
BROKER_TOKEN_ENC_KEY=




# Discipline defaults (used when seeding rules for a new user)
DEFAULT_MAX_TRADES_PER_DAY=3
DEFAULT_COOLDOWN_MINUTES=15
DEFAULT_MAX_DAILY_LOSS_PCT=2.0
DEFAULT_INITIAL_CAPITAL=100000

# Google OAuth (leave blank until Phase 2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/oauth/google/callback

# Frontend base URL used after Fyers callback
FRONTEND_URL=http://localhost:5173

